// ===== PULSE³ LEAGUE TABLES =====

enum LeagueRunType {
  SCHEDULED
  MANUAL
}

enum LeagueBandState {
  SECURE
  BELOW_RANGE
  ABOVE_RANGE
}

enum LeagueStatusChange {
  NEW
  UP
  DOWN
  UNCHANGED
  PROMOTED
  DEMOTED
  EXITED
}

model LeagueTier {
  id                   String   @id @default(cuid())
  code                 String   @unique // e.g. 'TIER1', 'TIER2'
  name                 String // e.g. 'Top 50', 'Watchlist'
  targetSize           Int // number of artists to show
  minScore             Float // desired lower bound (inclusive)
  maxScore             Float? // nullable upper bound (inclusive)
  refreshIntervalHours Int // how often this tier refreshes
  isActive             Boolean  @default(true)
  sortOrder            Int // UI ordering
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  leagueRuns LeagueRun[]

  @@index([code])
  @@index([isActive])
  @@index([sortOrder])
  @@map("league_tiers")
}

model LeagueRun {
  id        String        @id @default(cuid())
  tierId    String
  runType   LeagueRunType // 'SCHEDULED' | 'MANUAL'
  runAt     DateTime      @default(now())
  createdAt DateTime      @default(now())

  // Relations
  tier    LeagueTier    @relation(fields: [tierId], references: [id], onDelete: Cascade)
  entries LeagueEntry[]

  @@index([tierId])
  @@index([runAt])
  @@index([runType])
  @@map("league_runs")
}

model LeagueEntry {
  id              String             @id @default(cuid())
  leagueRunId     String
  artistProfileId String
  rank            Int // 1-based rank
  score           Float // eligibility score
  bandState       LeagueBandState // 'SECURE' | 'BELOW_RANGE' | 'ABOVE_RANGE'
  isAtRisk        Boolean
  previousRank    Int? // rank from previous run
  rankDelta       Int? // change in rank (positive = up, negative = down)
  statusChange    LeagueStatusChange // 'NEW' | 'UP' | 'DOWN' | 'UNCHANGED' | 'PROMOTED' | 'DEMOTED' | 'EXITED'
  highlight       Boolean            @default(false) // true if rank <= 3
  createdAt       DateTime           @default(now())

  // Relations
  leagueRun     LeagueRun     @relation(fields: [leagueRunId], references: [id], onDelete: Cascade)
  artistProfile ArtistProfile @relation("LeagueEntries", fields: [artistProfileId], references: [id], onDelete: Cascade)

  @@index([leagueRunId])
  @@index([artistProfileId])
  @@index([rank])
  @@index([bandState])
  @@map("league_entries")
}

